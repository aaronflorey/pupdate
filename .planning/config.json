{
  "mode": "interactive",
  "granularity": "standard",
  "model_profile": "balanced",
  "model_overrides": {
    "gsd-planner": "openai/gpt-5.4",
    "gsd-plan-checker": "openai/gpt-5.4",
    "gsd-verifier": "openai/gpt-5.4",
    "gsd-debugger": "openai/gpt-5.4",
    "gsd-security-auditor": "openai/gpt-5.4",
    "gsd-ui-checker": "openai/gpt-5.4",
    "gsd-ui-auditor": "openai/gpt-5.4",
    "gsd-doc-verifier": "openai/gpt-5.4",
    "gsd-executor": "openai/gpt-5.3-codex",
    "gsd-nyquist-auditor": "openai/gpt-5.3-codex",
    "gsd-doc-writer": "openai/gpt-5.3-codex",
    "gsd-phase-researcher": "openai/gpt-5.4-mini",
    "gsd-ui-researcher": "openai/gpt-5.4-mini",
    "gsd-project-researcher": "openai/gpt-5.4-mini",
    "gsd-roadmapper": "openai/gpt-5.4-mini",
    "gsd-research-synthesizer": "openai/gpt-5.4-mini",
    "gsd-integration-checker": "openai/gpt-5.4-mini",
    "gsd-assumptions-analyzer": "openai/gpt-5.4-mini",
    "gsd-advisor-researcher": "openai/gpt-5.4-mini",
    "gsd-user-profiler": "openai/gpt-5.4-mini",
    "gsd-codebase-mapper": "openai/gpt-5.4-nano",
    "gsd-intel-updater": "openai/gpt-5.4-nano"
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 4,
    "min_plans_for_parallel": 2
  },
  "git": {
    "base_branch": "main",
    "branching_strategy": "milestone",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": "gsd/quick-{num}-{slug}",
    "phase_branch_template": "gsd/phase-{phase}-{slug}"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": true,
    "nyquist_validation": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "research_before_questions": true,
    "discuss_mode": "assumptions",
    "skip_discuss": false,
    "use_worktrees": false,
    "code_review": true,
    "code_review_depth": "standard",
    "text_mode": false,
    "_auto_chain_active": false
  },
  "hooks": {
    "context_warnings": true
  },
  "features": {
    "global_learnings": true
  },
  "intel": {
    "enabled": true
  },
  "review": {
    "models": {
      "opencode": "openai/gpt-5.4"
    }
  },
  "claude_md_path": "./AGENTS.md",
  "resolve_model_ids": "omit",
  "runtime": "opencode",
  "commit_docs": false,
  "search_gitignored": true,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": true,
  "agent_skills": {},
  "model_profile_overrides": {
    "opencode": {
      "opus": "litellm/deepseek-v4-flash",
      "sonnet": "litellm/deepseek-v4-flash",
      "haiku": "litellm/deepseek-v4-flash"
    }
  }
}
